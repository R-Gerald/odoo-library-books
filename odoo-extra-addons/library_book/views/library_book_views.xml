<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_library_dashboard" model="ir.actions.client">
        <field name="name">Tableau de bord</field>
        <!-- DOIT correspondre exactement au tag dans le JS -->
        <field name="tag">library_book.dashboard_action</field>
    </record>

    <!-- Action : ouvre la liste des livres -->
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Livres</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Action : ouvre la liste des catégories -->
    <record id="action_library_book_category" model="ir.actions.act_window">
        <field name="name">Catégories</field>
        <field name="res_model">library.book.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu principal -->
    <menuitem id="menu_library_root"
              name="Bibliothèque"
              sequence="10"/>

    <menuitem id="menu_library_dashboard"
              name="Dashboard"
              parent="menu_library_root"
              action="action_library_dashboard"
              sequence="5"/>

    <!-- Sous-menu Livres -->
    <menuitem id="menu_library_book"
              name="Livres"
              parent="menu_library_root"
              action="action_library_book"
              sequence="10"/>

    <!-- Sous-menu Catégories -->
    <menuitem id="menu_library_book_category"
              name="Catégories"
              parent="menu_library_root"
              action="action_library_book_category"
              sequence="20"/>

    <!-- Vue liste (tree) Livres -->
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <tree string="Livres">
                <field name="name"/>
                <field name="author"/>
                <field name="published_date"/>
                <field name="category_id"/>
                <field name="is_available" widget="availability_widget"/>
            </tree>
        </field>
    </record>

         <!-- Vue formulaire (form) Livres -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Livre">
                <header>
                    <!-- Bouton simple, toujours visible -->
                    <button name="action_mark_unavailable"
                            type="object"
                            string="Marquer indisponible"
                            class="oe_highlight"/>
                    <button name="action_mark_available"
                            type="object"
                            string="Marquer disponible"
                            class="oe_highlight"/>
                    <button name="action_test_orm"
                            type="object"
                            string="Tester ORM"
                            class="btn-secondary"/>
                    <button name="action_mark_all_unavailable"
                            type="object"
                            string="Marquer tous indisponibles"
                            class="btn-warning"/>
                    <button name="action_delete_all_unavailable"
                            type="object"
                            string="Supprimer tous les indisponibles"
                            class="btn-danger"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="author"/>
                        <field name="published_date"/>
                        <field name="category_id"/>
                        <field name="is_available" widget="availability_widget"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Vue liste (tree) Catégories -->
    <record id="view_library_book_category_tree" model="ir.ui.view">
        <field name="name">library.book.category.tree</field>
        <field name="model">library.book.category</field>
        <field name="arch" type="xml">
            <tree string="Catégories">
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- Vue formulaire (form) Catégories -->
    <record id="view_library_book_category_form" model="ir.ui.view">
        <field name="name">library.book.category.form</field>
        <field name="model">library.book.category</field>
        <field name="arch" type="xml">
            <form string="Catégorie">
                <header>
                    <button name="action_open_books"
                            type="object"
                            string="Livres"
                            class="oe_stat_button"
                            icon="fa-book">
                        <field name="book_count" widget="statinfo"/>
                    </button>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                         <field name="book_count" readonly="1"/>
                        <field name="available_book_count" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

        <!-- Extension de la vue formulaire CRM pour ajouter le champ Type de projet -->
    <record id="view_crm_lead_form_inherit_project_type" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.project.type</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- On insère notre champ après le champ 'expected_revenue' -->
            <xpath expr="//field[@name='expected_revenue']" position="after">
                <field name="project_type"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_inherit_library" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.library</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="Bibliothèque">
                    <field name="library_book_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="author"/>
                            <field name="is_available"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>