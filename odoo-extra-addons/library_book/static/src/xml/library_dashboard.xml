<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="library_book.LibraryDashboard" owl="1">
        <div class="p-4">
            <h1 class="text-primary">Tableau de bord de la Bibliothèque</h1>

            <div class="mt-3" t-if="state.loading">
                <p>Chargement...</p>
            </div>

            <div class="mt-3" t-else="">
                <div class="d-flex gap-3 flex-wrap">
                    <div class="border rounded p-3">
                        <div class="text-muted">Livres au total</div>
                        <div class="fs-4"><t t-esc="state.stats.total_books"/></div>
                    </div>
                    <div class="border rounded p-3">
                        <div class="text-success">Disponibles</div>
                        <div class="fs-4 text-success"><t t-esc="state.stats.available_books"/></div>
                    </div>
                    <div class="border rounded p-3">
                        <div class="text-danger">Indisponibles</div>
                        <div class="fs-4 text-danger"><t t-esc="state.stats.unavailable_books"/></div>
                    </div>
                </div>

                <hr class="my-4"/>

                <div class="d-flex align-items-center gap-3">
                    <label class="fw-bold">Filtre:</label>
                    <select class="form-select w-auto" t-on-change="onFilterChange">
                        <option t-att-value="'all'" t-att-selected="state.filter === 'all'">Tous</option>
                        <option t-att-value="'available'" t-att-selected="state.filter === 'available'">Disponibles</option>
                        <option t-att-value="'unavailable'" t-att-selected="state.filter === 'unavailable'">Indisponibles</option>
                    </select>

                    <span class="ms-auto">
                        Counter local: <strong><t t-esc="state.counter"/></strong>
                    </span>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" t-on-click="increment">
                        Clique-moi !
                    </button>
                </div>

                <hr class="my-4"/>

                <h3>Livres (max 20)</h3>
                <table class="table table-sm table-striped mt-2">
                    <thead>
                        <tr>
                            <th>Titre</th>
                            <th>Auteur</th>
                            <th>Catégorie</th>
                            <th>Disponible</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="state.books.length === 0">
                            <tr>
                                <td colspan="4" class="text-muted">Aucun livre pour ce filtre.</td>
                            </tr>
                        </t>
                        <t t-foreach="state.books" t-as="b" t-key="b.id">
                            <tr>
                                <td><t t-esc="b.name"/></td>
                                <td><t t-esc="b.author"/></td>
                                <td>
                                    <t t-if="b.category_id">
                                        <t t-esc="b.category_id[1]"/>
                                    </t>
                                    <t t-else="">-</t>
                                </td>
                                <td>
                                    <t t-if="b.is_available">
                                        <span class="text-success fw-bold">Oui</span>
                                    </t>
                                    <t t-else="">
                                        <span class="text-danger fw-bold">Non</span>
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </t>

</templates>